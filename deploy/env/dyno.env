RUST_LOG=info
DYNO_PROFILE=production
# Use DYNO_SOURCE_MODE=replay for dev/test (no ESP32 required).
# Use DYNO_SOURCE_MODE=live for production with a connected ESP32.
DYNO_SOURCE_MODE=live
DYNO_SERIAL_PORT=/dev/ttyUSB0
DYNO_SERIAL_BAUD=115200
DYNO_CAN_IFACE=can0
DYNO_STORAGE_DB_PATH=/var/lib/dyno/runs-rust.db
DYNO_MODBUS_AFR_ENABLED=false
DYNO_ENABLE_DEV_API=true
