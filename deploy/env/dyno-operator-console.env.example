# Dyno operator console environment

# Backend API and websocket endpoints
DYNO_UI_API_BASE_URL=http://127.0.0.1:9001
DYNO_UI_WS_URI=ws://127.0.0.1:9000

# Optional external run-control API
DYNO_CONTROL_API_BASE_URL=http://127.0.0.1:8080

# Window behavior
DYNO_UI_MODE=maximized
# DYNO_UI_FULLSCREEN=true
DYNO_UI_MAXIMIZE_TO_FULLSCREEN=true

# Required when starting JavaFX from systemd on a desktop session
# DISPLAY=:0
# XAUTHORITY=/home/dyno/.Xauthority
# DYNO_OPERATOR_CONSOLE_HOME=/opt/dyno-operator-console
